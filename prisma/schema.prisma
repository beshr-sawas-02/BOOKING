generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EmbassyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum PackageType {
  HAJJ
  UMRAH
}

enum Gender {
  MALE
  FEMALE
}

enum RelationType {
  PRIMARY
  SPOUSE
  SON
  DAUGHTER
  MOTHER
  FATHER
  BROTHER
  SISTER
  GRANDSON
  GRANDDAUGHTER
  SON_WIFE
  DAUGHTER_HUSBAND
  NEPHEW
  NIECE
  BROTHER_WIFE
  SISTER_HUSBAND
  OTHER
}

enum ImageType {
  FRONT
  BACK
}

model User {
  user_id        BigInt   @id @default(autoincrement())
  email          String   @unique
  password       String
  email_verified Boolean  @default(false)
  full_name      String
  phone_number   String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  bookings               Booking[]
  booking_participants   BookingParticipant[]
  passports              Passport[]
  family_proof_documents FamilyProofDocument[]
  reviews                PackageReview[]

  @@map("users")
}

model Admin {
  admin_id   BigInt    @id @default(autoincrement())
  full_name  String
  email      String    @unique
  password   String
  role       AdminRole @default(ADMIN)
  last_login DateTime?
  created_at DateTime  @default(now())

  @@map("admins")
}

model Package {
  package_id       BigInt      @id @default(autoincrement())
  package_title    String
  package_type     PackageType
  category         String
  description      String?
  duration_days    Int
  price_per_person Decimal     @db.Decimal(10, 2)
  max_participants Int
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  bookings       Booking[]
  package_hotels PackageHotel[]
  reviews        PackageReview[]

  @@map("packages")
}

model Hotel {
  hotel_id    BigInt   @id @default(autoincrement())
  hotel_name  String
  stars       Int
  room_types  String?
  description String?
  location    String
  latitude    Float?
  longitude   Float?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  hotel_images   HotelImage[]
  package_hotels PackageHotel[]

  @@map("hotels")
}

model PackageHotel {
  id         BigInt @id @default(autoincrement())
  package_id BigInt
  hotel_id   BigInt

  package Package @relation(fields: [package_id], references: [package_id], onDelete: Cascade)
  hotel   Hotel   @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@unique([package_id, hotel_id])
  @@map("package_hotels")
}

model HotelImage {
  image_id    BigInt   @id @default(autoincrement())
  hotel_id    BigInt
  image_url   String
  image_order Int      @default(0)
  uploaded_at DateTime @default(now())

  hotel Hotel @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@map("hotel_images")
}

model Booking {
  booking_id             BigInt        @id @default(autoincrement())
  user_id                BigInt
  package_id             BigInt
  booking_status         BookingStatus @default(PENDING)
  total_price            Decimal       @db.Decimal(10, 2)
  deposit_due_date       DateTime?
  final_payment_due_date DateTime?
  trip_end_date          DateTime?     @db.Date
  created_at             DateTime      @default(now())
  updated_at             DateTime      @updatedAt

  user                   User                  @relation(fields: [user_id], references: [user_id])
  package                Package               @relation(fields: [package_id], references: [package_id])
  booking_participants   BookingParticipant[]
  embassy_results        EmbassyResult[]
  family_proof_documents FamilyProofDocument[]

    review PackageReview?

  @@map("bookings")
}

model BookingParticipant {
  participant_id  BigInt       @id @default(autoincrement())
  booking_id      BigInt
  user_id         BigInt?
  passport_id     BigInt?      @unique
  full_name       String
  relation_type   RelationType
  is_primary      Boolean      @default(false)
  family_proof_id BigInt?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  booking      Booking              @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  user         User?                @relation(fields: [user_id], references: [user_id])
  passport     Passport?            @relation(fields: [passport_id], references: [passport_id])
  family_proof FamilyProofDocument? @relation(fields: [family_proof_id], references: [document_id])

  @@map("booking_participants")
}

model Passport {
  passport_id           BigInt    @id @default(autoincrement())
  user_id               BigInt
  participant_id        BigInt?
  full_name_en          String?
  full_name_ar          String?
  passport_number       String    @unique
  nationality           String?
  gender                Gender?
  date_of_birth         DateTime? @db.Date
  issue_date            DateTime? @db.Date
  expiry_date           DateTime? @db.Date
  ai_extracted          Boolean   @default(false)
  extraction_confidence Float?
  verified_by_admin     Boolean   @default(false)
  sent_to_embassy       Boolean   @default(false)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  user            User                @relation(fields: [user_id], references: [user_id])
  passport_images PassportImage[]
  embassy_results EmbassyResult[]
  participant     BookingParticipant?

  @@map("passports")
}

model PassportImage {
  image_id    BigInt    @id @default(autoincrement())
  passport_id BigInt
  image_url   String
  image_type  ImageType
  uploaded_at DateTime  @default(now())

  passport Passport @relation(fields: [passport_id], references: [passport_id], onDelete: Cascade)

  @@map("passport_images")
}

model EmbassyResult {
  result_id      BigInt        @id @default(autoincrement())
  booking_id     BigInt
  passport_id    BigInt
  embassy_status EmbassyStatus @default(PENDING)
  notes          String?
  uploaded_at    DateTime      @default(now())

  booking  Booking  @relation(fields: [booking_id], references: [booking_id])
  passport Passport @relation(fields: [passport_id], references: [passport_id])

  @@map("embassy_results")
}

model FamilyProofDocument {
  document_id         BigInt             @id @default(autoincrement())
  uploaded_by         BigInt
  booking_id          BigInt
  document_url        String
  document_type       String
  father_name         String?
  mother_name         String?
  im_extracted        Boolean            @default(false)
  verification_status VerificationStatus @default(PENDING)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  uploader             User                 @relation(fields: [uploaded_by], references: [user_id])
  booking              Booking              @relation(fields: [booking_id], references: [booking_id])
  booking_participants BookingParticipant[]

  @@map("family_proof_documents")
}

model PackageReview {
  review_id   BigInt   @id @default(autoincrement())
  package_id  BigInt
  user_id     BigInt
  booking_id  BigInt   @unique  // كل حجز مرة وحدة فقط
  rating      Int      // 1-5
  comment     String?
  created_at  DateTime @default(now())

  package Package @relation(fields: [package_id], references: [package_id])
  user    User    @relation(fields: [user_id], references: [user_id])
  booking Booking @relation(fields: [booking_id], references: [booking_id])

  @@unique([user_id, package_id])  // مستخدم واحد يقيّم الباقة مرة وحدة
  @@map("package_reviews")
}
